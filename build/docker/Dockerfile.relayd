FROM golang:1.26.2-bookworm AS builder

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates git && rm -rf /var/lib/apt/lists/*

COPY shared/registryauth ./shared/registryauth
COPY relayd ./relayd

WORKDIR /app/relayd

RUN go mod download
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /out/relayd .

FROM gcr.io/distroless/static-debian12

COPY --from=builder /out/relayd /relayd

ENTRYPOINT ["/relayd"]
